{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HakDoc",
  "version": "0.1.0",
  "identifier": "com.hakdoc.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "node scripts/bundle-server.js",
    "devUrl": "http://localhost:14296",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "HakDoc",
        "url": "http://localhost:14296",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "server-dist/server.js": "server.js",
      "server-dist/package.json": "package.json",
      "server-dist/ai/prompts.js": "ai/prompts.js",
      "server-dist/ai/provider.js": "ai/provider.js",
      "server-dist/ai/routes.js": "ai/routes.js",
      "server-dist/node_modules/**/*": "node_modules/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
