{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HakDoc",
  "version": "0.1.0",
  "identifier": "com.hakdoc.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:14296",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "HakDoc",
        "url": "http://localhost:14296",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
